# 高德地图API配置
AMAP_API_KEY=YOUR_AMAP_API_KEY

# 商户配置
MERCHANT_LONGITUDE=116.310918
MERCHANT_LATITUDE=39.992873

# 配送范围
DELIVERY_RADIUS=3000

# 默认路径规划模式 (1-步行距离，2-骑行(电动车)距离，3-驾车距离)
DEFAULT_PATH_MODE=2

# LLM配置
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY
DASHSCOPE_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1/"
EMBEDDING_MODEL=text-embedding-v4

CLOSEAI_API_KEY=YOUR_CLOSEAI_API_KEY
CLOSEAI_API_BASE="https://api.openai-proxy.org/v1"
CLOSEAI_LLM_MODEL=gpt-5.2
CLOSEAI_RAG_MODEL=gpt-4o-mini


# Pinecone向量数据库配置
PINECONE_API_KEY=YOUR-PINECONE-API-KEY
PINECONE_ENV=us-east-1
PINECONE_INDEX_NAME=smart-menu-index

# MySQL数据库配置
MYSQL_HOST="localhost"
MYSQL_PORT=3306
MYSQL_USER_NAME="root"
MYSQL_USER_PASSWORD="123456"
MYSQL_DB_NAME="smart_menu"
